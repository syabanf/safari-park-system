# Mocks default ON (no real backend yet). Set to "false" once the WIT API is up.
VITE_API_BASE_URL=/api/v1
VITE_USE_MOCKS=true
VITE_PLATFORM=web

# Optional — override cross-app links if you deploy each app to its own domain.
# Single-root deploys use /member/, /validator/, /admin/ on the same origin automatically.
# VITE_MEMBER_URL=https://my-member.example.com
# VITE_VALIDATOR_URL=https://my-validator.example.com
# VITE_ADMIN_URL=https://my-admin.example.com
