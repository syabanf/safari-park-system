{
  "name": "taman-safari",
  "version": "0.1.0",
  "private": true,
  "description": "Taman Safari Indonesia — Annual Pass frontend (Member PWA + Gate Validator)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "lefthook": "^1.7.18",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  }
}
